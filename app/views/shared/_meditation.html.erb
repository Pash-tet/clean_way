<article class="bg-base-200 border-base-400 collapse-arrow collapse border">
  <input type="checkbox" />
  <div class="collapse-title text-xl font-bold">
    <%= l(Date.new(0, meditation.month, meditation.day), format: "%d %B") %>. <%= meditation.title %>
    <br />
  </div>
  <div class="collapse-content text-justify">
    <p class="italic"><%= meditation.quote %></p>
    <p class="text-right italic"><%= meditation.quote_source %></p>
    <p class="mt-4"><%= meditation.text %></p>
  </div>
</article>
